# SearXNG 实例环境变量
# 复制此文件为 .env 并填写实际值

# Secret Key（必填，生产环境请使用强密码）
SEARXNG_SECRET=changeme

# --- 付费模式 API Key（按需填写） ---

# Google Custom Search API
# https://developers.google.com/custom-search/v1/overview
GOOGLE_API_KEY=
GOOGLE_ENGINE_ID=

# Bing Web Search API
# https://www.microsoft.com/en-us/bing/apis
BING_API_KEY=

# YouTube Data API v3
# https://developers.google.com/youtube/v3
YOUTUBE_API_KEY=

# WolframAlpha API
# https://products.wolframalpha.com/api/
WOLFRAMALPHA_API_KEY=

# DeepL API
# https://www.deepl.com/pro-api
DEEPL_API_KEY=

# Flickr API
# https://www.flickr.com/services/apps/create/
FLICKR_API_KEY=
