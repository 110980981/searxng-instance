# SearXNG 实例环境变量
# 复制此文件为 .env 并填写实际值

# Secret Key（必填，生产环境请使用强密码）
SEARXNG_SECRET=changeme

# --- 付费模式 API Key（按需填写） ---

# Google Custom Search API
# https://developers.google.com/custom-search/v1/overview
GOOGLE_API_KEY=
GOOGLE_ENGINE_ID=

# Bing Web Search API
# https://www.microsoft.com/en-us/bing/apis
BING_API_KEY=

# YouTube Data API v3
# https://developers.google.com/youtube/v3
YOUTUBE_API_KEY=

# WolframAlpha API
# https://products.wolframalpha.com/api/
WOLFRAMALPHA_API_KEY=

# DeepL API
# https://www.deepl.com/pro-api
DEEPL_API_KEY=

# Flickr API
# https://www.flickr.com/services/apps/create/
FLICKR_API_KEY=

# Brave Search API
# https://brave.com/search/api/
# SearXNG Brave 引擎默认用 HTML 抓取，如需官方 API 可参考配置
BRAVE_API_KEY=

# Serper.dev API (Google Search API)
# https://serper.dev/
# SearXNG 无内置 Serper 引擎，需自定义 json_engine 配置
SERPER_API_KEY=
