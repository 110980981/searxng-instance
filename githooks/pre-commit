#!/usr/bin/env bash
# pre-commit hook: 阻止 API Key / Secret 被意外提交
# 安装: git config core.hooksPath githooks
set -e

RED='\033[0;31m'
NC='\033[0m'

# 常见 API Key 正则模式（匹配 .env 文件或代码中的占位符）
PATTERNS=(
    '(?i)api[_-]?key\s*[=:]\s*["'\'']?[A-Za-z0-9_\-]{20,}["'\'']?'
    '(?i)secret\s*[=:]\s*["'\'']?[A-Za-z0-9_\-]{8,}["'\'']?'
    '(?i)token\s*[=:]\s*["'\'']?[A-Za-z0-9_\-.]{20,}["'\'']?'
    '(?i)password\s*[=:]\s*["'\'']?[A-Za-z0-9_\-@#$%!]{8,}["'\'']?'
    'ghp_[A-Za-z0-9_]{36,}'          # GitHub Personal Access Token
    'gho_[A-Za-z0-9_]{36,}'          # GitHub OAuth Token
    'sk-[A-Za-z0-9_]{32,}'           # OpenAI API Key
    'AIza[0-9A-Za-z\-_]{35}'         # Google API Key
    'AKIA[0-9A-Z]{16}'               # AWS Access Key
)
# 允许的文件（排除 .env.example 中的占位符）
ALLOW_LIST=(
    '.env.example'
    'githooks/'
)

BLOCKED=0

# 只检查 staged 文件
while IFS= read -r -d '' file; do
    basename=$(basename "$file")

    # 跳过允许列表
    skip=0
    for allow in "${ALLOW_LIST[@]}"; do
        if [[ "$file" == *"$allow"* ]]; then
            skip=1
            break
        fi
    done
    [[ $skip -eq 1 ]] && continue

    # 跳过删除的文件
    if ! git diff --cached --name-status "$file" | grep -q '^[AM]'; then
        continue
    fi

    content=$(git diff --cached -- "$file" | grep '^+' | sed 's/^+//')

    for pattern in "${PATTERNS[@]}"; do
        if echo "$content" | grep -qE "$pattern"; then
            echo -e "${RED}[SECURITY] 发现可能的密钥泄漏: $file${NC}"
            echo "$content" | grep -E --color=always "$pattern"
            BLOCKED=1
        fi
    done
done < <(git diff --cached --name-only -z)

if [[ $BLOCKED -eq 1 ]]; then
    echo ""
    echo -e "${RED}╔══════════════════════════════════════════════════════════╗${NC}"
    echo -e "${RED}║  提交被阻止: 检测到可能的 API Key/Secret 泄漏          ║${NC}"
    echo -e "${RED}║  请移除密钥信息, 改用以下方式:                         ║${NC}"
    echo -e "${RED}║  1. 放入 .env 文件 (已被 .gitignore 排除)              ║${NC}"
    echo -e "${RED}║  2. 使用 SEARXNG_SECRET 等环境变量传入                  ║${NC}"
    echo -e "${RED}║  3. 在 settings.yml 中使用 !ENV 引用环境变量            ║${NC}"
    echo -e "${RED}║                                                         ║${NC}"
    echo -e "${RED}║  如需强制提交: git commit --no-verify                   ║${NC}"
    echo -e "${RED}╚══════════════════════════════════════════════════════════╝${NC}"
    exit 1
fi

exit 0
